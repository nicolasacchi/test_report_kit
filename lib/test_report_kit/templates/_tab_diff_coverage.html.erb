<% if diff_cov -%>

<div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
  <div style="font-size: 48px; font-weight: 800; color: <%= coverage_color(diff_cov.diff_coverage_pct) %>; letter-spacing: -2px;">
    <%= diff_cov.diff_coverage_pct ? "#{diff_cov.diff_coverage_pct}%" : "N/A" %>
  </div>
  <div>
    <div style="font-size: 14px; font-weight: 700; color: var(--text-primary);">of changed lines are covered</div>
    <div style="font-size: 12px; color: var(--text-muted); font-family: var(--mono); margin-top: 4px;">
      <%= diff_cov.covered_changed_lines %> covered &middot; <%= diff_cov.uncovered_changed_lines %> uncovered &middot; <%= diff_cov.executable_changed_lines %> executable &middot; <%= diff_cov.total_changed_lines %> total changed
    </div>
    <div style="font-size: 11px; color: var(--text-muted); font-family: var(--mono); margin-top: 2px;">
      compared against <code style="background: var(--bg-elevated); padding: 1px 6px; border-radius: 3px; color: var(--text-secondary);"><%= h(diff_cov.base_branch) %></code>
      at <code style="background: var(--bg-elevated); padding: 1px 6px; border-radius: 3px; color: var(--text-secondary);"><%= h(diff_cov.base_sha) %></code>
    </div>
  </div>
  <div style="margin-left: auto;">
    <% if diff_cov.passed -%>
    <span class="badge badge-pass">above <%= diff_cov.threshold %>% threshold</span>
    <% elsif diff_cov.passed == false -%>
    <span class="badge badge-fail">below <%= diff_cov.threshold %>% threshold</span>
    <% end -%>
  </div>
</div>

<%# Per-file diff coverage table %>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Per-File Diff Coverage</div>
  </div>
  <table>
    <thead>
      <tr>
        <th data-sort>File</th>
        <th data-sort>Diff Cov</th>
        <th data-sort>Changed</th>
        <th data-sort>Covered</th>
        <th data-sort>Uncovered</th>
      </tr>
    </thead>
    <tbody>
      <% diff_cov.files.each do |f| -%>
      <tr>
        <td><span class="file-path"><%= h(f.path) %></span></td>
        <td>
          <div class="cov-bar">
            <div class="cov-bar-track"><div class="cov-bar-fill" style="width:<%= f.diff_coverage_pct || 0 %>%; background: <%= coverage_color(f.diff_coverage_pct) %>;"></div></div>
            <span class="cov-pct" style="color: <%= coverage_color(f.diff_coverage_pct) %>;"><%= f.diff_coverage_pct ? "#{f.diff_coverage_pct}%" : "N/A" %></span>
          </div>
        </td>
        <td><span class="num"><%= f.changed_lines.size %></span></td>
        <td><span class="num" style="color: var(--green);"><%= f.covered_lines.size %></span></td>
        <td><span class="num" style="color: <%= f.uncovered_lines.any? ? 'var(--red)' : 'var(--text-muted)' %>;<%= f.uncovered_lines.size > 10 ? ' font-weight: 700;' : '' %>"><%= f.uncovered_lines.size %></span></td>
      </tr>
      <% end -%>
    </tbody>
  </table>
</div>

<%# Uncovered lines detail %>
<% uncovered_files = diff_cov.files.select { |f| f.uncovered_lines.any? } -%>
<% if uncovered_files.any? -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Uncovered Changed Lines</div>
  </div>
  <% uncovered_files.each do |f| -%>
  <div class="diff-file-section">
    <div class="diff-file-header"<%= uncovered_files.index(f) > 0 ? ' style="border-top: 1px solid var(--border);"' : '' %>>
      <div class="diff-file-toggle">
        <span class="diff-arrow" style="color: var(--text-muted); font-size: 12px;">&#9660;</span>
        <span class="file-path" style="max-width: none;"><%= h(f.path) %></span>
        <span class="diff-badge" style="color: var(--red); background: var(--red-dim);">
          <%= f.uncovered_lines.size %> uncovered line<%= f.uncovered_lines.size == 1 ? '' : 's' %><%= f.not_loaded ? ' — not loaded by tests' : '' %>
        </span>
      </div>
    </div>
    <div class="diff-file-content">
      <% if f.not_loaded -%>
      <div style="padding: 16px 20px; color: var(--red); font-size: 12px; font-family: var(--mono); background: rgba(239, 68, 68, 0.04);">
        this file was never loaded during the test suite. no specs exist for it. all <%= f.uncovered_lines.size %> changed lines are uncovered.
      </div>
      <% else -%>
        <% f.uncovered_content.each do |entry| -%>
          <% if entry[:type] == :gap -%>
          <div class="diff-gap"></div>
          <% elsif entry[:type] == :context -%>
          <div class="diff-line" style="background: rgba(34, 197, 94, 0.04);">
            <div class="diff-line-num" style="color: var(--text-muted); border-right: 3px solid rgba(34, 197, 94, 0.3);"><%= entry[:line] %></div>
            <div class="diff-line-code" style="color: var(--text-secondary);"><%= highlight_ruby(entry[:content]) %></div>
          </div>
          <% else -%>
          <div class="diff-line" style="background: rgba(239, 68, 68, 0.06);">
            <div class="diff-line-num" style="color: var(--red); border-right: 3px solid var(--red); font-weight: 600;"><%= entry[:line] %></div>
            <div class="diff-line-code" style="color: var(--text-primary);"><%= highlight_ruby(entry[:content]) %></div>
          </div>
          <% end -%>
        <% end -%>
      <% end -%>
    </div>
  </div>
  <% end -%>
</div>
<% end -%>

<%# Summary stat cards %>
<%
  total_files = diff_cov.files.size
  full_cov = diff_cov.files.count { |f| f.diff_coverage_pct && f.diff_coverage_pct >= 100 }
  partial_cov = diff_cov.files.count { |f| f.diff_coverage_pct && f.diff_coverage_pct > 0 && f.diff_coverage_pct < 100 }
  not_loaded = diff_cov.files.count { |f| f.not_loaded }
-%>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 16px;">
  <div style="background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 14px 18px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600;">files changed</div>
    <div style="font-size: 24px; font-weight: 800; color: var(--text-primary); margin-top: 4px;"><%= total_files %></div>
  </div>
  <div style="background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 14px 18px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600;">100% covered</div>
    <div style="font-size: 24px; font-weight: 800; color: var(--green); margin-top: 4px;"><%= full_cov %></div>
  </div>
  <div style="background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 14px 18px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600;">partially covered</div>
    <div style="font-size: 24px; font-weight: 800; color: var(--yellow); margin-top: 4px;"><%= partial_cov %></div>
  </div>
  <div style="background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 8px; padding: 14px 18px;">
    <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); font-weight: 600;">not loaded by tests</div>
    <div style="font-size: 24px; font-weight: 800; color: var(--red); margin-top: 4px;"><%= not_loaded %></div>
  </div>
</div>

<% else -%>
<div class="empty-state">
  Diff coverage is not available. This report was either generated on the base branch or git diff could not be computed.
</div>
<% end -%>
