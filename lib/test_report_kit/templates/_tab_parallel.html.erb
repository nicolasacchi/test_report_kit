<% pi = parallel_info -%>
<% if pi -%>

<div style="display: flex; align-items: center; gap: 16px; margin-bottom: 20px;">
  <div style="font-size: 48px; font-weight: 800; color: var(--accent); letter-spacing: -2px;"><%= pi["node_count"] %></div>
  <div>
    <div style="font-size: 14px; font-weight: 700; color: var(--text-primary);">parallel nodes</div>
    <div style="font-size: 12px; color: var(--text-muted); font-family: var(--mono); margin-top: 4px;">
      wall clock: <%= format_duration_val(pi["wall_clock_seconds"]) %> &middot;
      total CPU: <%= format_duration_val(pi["total_cpu_seconds"]) %> &middot;
      efficiency: <span style="color: <%= pi["efficiency"].to_f >= 80 ? 'var(--green)' : pi["efficiency"].to_f >= 60 ? 'var(--yellow)' : 'var(--red)' %>; font-weight: 600;"><%= pi["efficiency"] %>%</span>
    </div>
  </div>
</div>

<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Per-Node Breakdown</div>
  </div>
  <table>
    <thead>
      <tr>
        <th data-sort>Node</th>
        <th data-sort>Examples</th>
        <th data-sort>Duration</th>
        <th data-sort>Failures</th>
        <th>Slowest Test</th>
      </tr>
    </thead>
    <tbody>
      <% (pi["nodes"] || []).each do |n| -%>
      <tr>
        <td><span class="num" style="color: var(--cyan); font-weight: 600;"><%= h(n["node"]) %></span></td>
        <td><span class="num"><%= n["examples"] %></span></td>
        <td><span class="num" style="font-weight: 700;"><%= format_duration_val(n["duration"]) %></span></td>
        <td><span class="num" style="color: <%= n["failures"].to_i > 0 ? 'var(--red)' : 'var(--green)' %>;"><%= n["failures"] %></span></td>
        <td style="font-size: 11px; color: var(--text-muted); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= h(n["slowest_test"].to_s) %> (<%= n["slowest_duration"] %>s)</td>
      </tr>
      <% end -%>
    </tbody>
  </table>
</div>

<%# Duration balance visualization %>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Duration Balance</div>
  </div>
  <div style="padding: 16px 20px;">
    <% max_dur = (pi["nodes"] || []).map { |n| n["duration"].to_f }.max || 1 -%>
    <% (pi["nodes"] || []).each do |n| -%>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
      <div style="width: 60px; text-align: right; font-family: var(--mono); font-size: 11px; color: var(--text-muted); flex-shrink: 0;"><%= h(n["node"]) %></div>
      <div style="flex: 1; height: 22px; background: var(--bg-elevated); border-radius: 4px; overflow: hidden;">
        <div style="width: <%= (n["duration"].to_f / max_dur * 100).round(0) %>%; height: 100%; background: var(--accent); opacity: 0.7; border-radius: 4px; display: flex; align-items: center; padding-left: 8px;">
          <span style="font-family: var(--mono); font-size: 10px; color: #fff; white-space: nowrap;"><%= format_duration_val(n["duration"]) %></span>
        </div>
      </div>
      <div style="width: 50px; font-family: var(--mono); font-size: 11px; color: var(--text-secondary);"><%= n["examples"] %> ex</div>
    </div>
    <% end -%>
  </div>
</div>

<%# Balance warnings %>
<% warnings = pi["balance"] || [] -%>
<% if warnings.any? -%>
<div class="insight-section">
  <div class="insight-header">
    <div class="insight-icon" style="background: var(--yellow-dim); color: var(--yellow);">&#9878;</div>
    <div class="insight-title">Balance Suggestions</div>
  </div>
  <% warnings.each do |w| -%>
  <div class="suggestion"><%= h(w["message"]) %></div>
  <% end -%>
</div>
<% end -%>

<% else -%>
<div class="empty-state">No parallel run data available. Use <code>rake test_report:merge[pattern]</code> to merge parallel artifacts.</div>
<% end -%>
