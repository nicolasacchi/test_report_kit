<%# ── Time Distribution Overview ── %>
<% if test_time_distribution -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Test Duration Distribution</div>
    <div style="font-size: 11px; color: var(--text-muted); font-family: var(--mono);">
      <% if rspec_summary -%>
      <%= format_number(rspec_summary[:example_count]) %> examples &middot; <%= rspec_summary[:duration_formatted] %> total
      <% end -%>
    </div>
  </div>
  <div style="padding: 16px 20px;">
    <% test_time_distribution.each do |bucket| -%>
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 6px;">
      <div style="width: 80px; text-align: right; font-family: var(--mono); font-size: 11px; color: var(--text-muted); flex-shrink: 0;"><%= bucket[:label] %></div>
      <div style="flex: 1; height: 18px; background: var(--bg-elevated); border-radius: 3px; overflow: hidden;">
        <div style="width: <%= bucket[:pct] %>%; height: 100%; background: <%= bucket[:color] %>; opacity: 0.7; border-radius: 3px; min-width: <%= bucket[:count] > 0 ? '2px' : '0' %>;"></div>
      </div>
      <div style="width: 50px; font-family: var(--mono); font-size: 11px; color: var(--text-secondary);"><%= bucket[:count] %></div>
    </div>
    <% end -%>
  </div>
</div>
<% end -%>

<%# ── Time by Spec File ── %>
<% if time_by_file.any? -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Time by Spec File</div>
  </div>
  <table>
    <thead>
      <tr>
        <th data-sort>File</th>
        <th data-sort>Total Time</th>
        <th data-sort>Examples</th>
        <th data-sort>Avg Time</th>
        <th>Slowest Example</th>
      </tr>
    </thead>
    <tbody>
      <% time_by_file.each do |f| -%>
      <tr>
        <td><span class="file-path"><% fp = f[:file].to_s.sub(%r{^\./}, ''); %><%= file_link(fp) %></span></td>
        <td><span class="num" style="font-weight: 700;"><%= f[:total_time] %>s</span></td>
        <td><span class="num"><%= f[:count] %></span></td>
        <td><span class="num"><%= f[:avg_time] %>s</span></td>
        <td style="font-size: 11px; color: var(--text-muted); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= h(f[:slowest_description].to_s[0..60]) %> (<%= f[:slowest_duration] %>s)</td>
      </tr>
      <% end -%>
    </tbody>
  </table>
</div>
<% end -%>

<%# ── Slowest Examples (expandable) ── %>
<% if slowest_tests.any? -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Slowest Examples (top 20)</div>
    <span style="font-size: 11px; color: var(--text-muted);">click a test to view source</span>
  </div>
  <table>
    <thead>
      <tr>
        <th data-sort>Example</th>
        <th data-sort>File</th>
        <th data-sort>Duration</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% slowest_tests.each do |t| -%>
      <%
        parts = t[:file].to_s.sub(%r{^\./}, '').split(':')
        test_file = parts[0]
        test_line = parts[1]&.to_i
      -%>
      <tr class="perf-test-row" style="cursor: pointer;">
        <td style="color: var(--text-primary); max-width: 400px;"><%= h(t[:description]) %></td>
        <td><span class="file-path"><%= file_link(test_file, line: test_line) %><%= test_line ? ":#{test_line}" : "" %></span></td>
        <td><span class="num" style="color: <%= t[:slow] ? 'var(--red)' : 'var(--yellow)' %>; font-weight: 700;"><%= t[:duration] %>s</span></td>
        <td><span class="badge badge-<%= t[:status] == 'passed' ? 'pass' : 'fail' %>"><%= t[:status] == 'passed' ? 'pass' : t[:status] %></span></td>
      </tr>
      <% source_lines = build_test_source(test_file, test_line) -%>
      <% if source_lines -%>
      <tr class="perf-test-detail" style="display:none;">
        <td colspan="4" style="padding: 0;">
          <div style="padding: 12px 20px; background: var(--bg-surface); border-bottom: 1px solid var(--border-subtle);">
            <% if t[:exception] -%>
            <div style="margin-bottom: 12px; padding: 12px 16px; background: var(--red-dim); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 8px;">
              <div style="font-size: 11px; color: var(--red); text-transform: uppercase; letter-spacing: 1px; font-weight: 600; margin-bottom: 6px;">Failure</div>
              <div style="font-family: var(--mono); font-size: 12px; color: var(--red); font-weight: 600; margin-bottom: 4px;"><%= h(t[:exception][:class]) %></div>
              <div style="font-family: var(--mono); font-size: 12px; color: var(--text-primary); line-height: 1.6;"><%= h(t[:exception][:message]) %></div>
              <% if t[:exception][:backtrace]&.any? -%>
              <div style="font-family: var(--mono); font-size: 10px; color: var(--text-muted); margin-top: 8px; line-height: 1.6;">
                <% t[:exception][:backtrace].each do |line| -%>
                <div><%= h(line) %></div>
                <% end -%>
              </div>
              <% end -%>
            </div>
            <% end -%>
            <div style="display: flex; gap: 16px;">
              <div style="flex: 1;">
                <div style="font-size: 11px; color: var(--text-muted); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Test Source</div>
                <div class="file-viewer" style="max-height: 300px;">
                  <% source_lines.each do |sl| -%>
                  <div class="cov-line cov-line-none">
                    <% if @config.github_url -%>
                    <a href="<%= h(@config.github_url) %>/blob/<%= sha %>/<%= test_file %>#L<%= sl[:line] %>" target="_blank" rel="noopener" class="cov-line-num"><%= sl[:line] %></a>
                    <% else -%>
                    <div class="cov-line-num"><%= sl[:line] %></div>
                    <% end -%>
                    <div class="cov-line-code"><%= highlight_ruby(sl[:content]) %></div>
                  </div>
                  <% end -%>
                </div>
              </div>
              <% if @config.github_url -%>
              <div style="flex-shrink: 0; padding-top: 24px;">
                <a href="<%= h(@config.github_url) %>/blob/<%= sha %>/<%= test_file %>#L<%= test_line %>" target="_blank" rel="noopener" style="font-size: 11px; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 4px;">
                  <%= GH_ICON_SVG %>
                  View on GitHub
                </a>
            </div>
            <% end -%>
          </div>
        </td>
      </tr>
      <% end -%>
      <% end -%>
    </tbody>
  </table>
</div>
<% else -%>
<div class="empty-state">No test performance data available.</div>
<% end -%>

<%# ── RSpecDissect Time Distribution ── %>
<% if rspec_dissect_data && rspec_dissect_data["suites"]&.any? -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Setup vs Example Time (RSpecDissect)</div>
  </div>
  <div style="padding: 16px 20px 4px;">
    <div class="time-legend">
      <span><span class="time-legend-dot" style="background: var(--red); opacity: 0.7;"></span> before hooks</span>
      <span><span class="time-legend-dot" style="background: var(--yellow); opacity: 0.7;"></span> let declarations</span>
      <span><span class="time-legend-dot" style="background: var(--green); opacity: 0.7;"></span> examples</span>
    </div>
  </div>
  <table>
    <thead>
      <tr>
        <th>File</th>
        <th>Total</th>
        <th>Distribution</th>
        <th data-sort>before</th>
        <th data-sort>let</th>
        <th data-sort>examples</th>
      </tr>
    </thead>
    <tbody>
      <% rspec_dissect_data["suites"].each do |suite| -%>
      <tr>
        <td><span class="file-path"><% loc_parts = suite["location"].to_s.sub('./', '').split(':'); %><%= file_link(loc_parts[0], line: loc_parts[1]&.to_i) %></span></td>
        <td><span class="num"><%= suite["total_time"] %></span></td>
        <td>
          <div class="time-bar">
            <div class="time-bar-before" style="width: <%= suite["before_pct"] || 0 %>%;"></div>
            <div class="time-bar-let" style="width: <%= suite["let_pct"] || 0 %>%;"></div>
            <div class="time-bar-example" style="width: <%= suite["example_pct"] || 0 %>%;"></div>
          </div>
        </td>
        <td><span class="num" style="color: var(--red);"><%= suite["before_time"] %> (<%= suite["before_pct"] ? "#{suite["before_pct"].round(0)}%" : "—" %>)</span></td>
        <td><span class="num" style="color: var(--yellow);"><%= suite["let_time"] %> (<%= suite["let_pct"] ? "#{suite["let_pct"].round(0)}%" : "—" %>)</span></td>
        <td><span class="num" style="color: var(--green);"><%= suite["example_time"] %> (<%= suite["example_pct"] ? "#{suite["example_pct"].round(0)}%" : "—" %>)</span></td>
      </tr>
      <% end -%>
    </tbody>
  </table>
</div>
<% end -%>

<%# ── EventProf ── %>
<% if event_prof_data && event_prof_data["suites"]&.any? -%>
<div class="table-wrap">
  <div class="table-header">
    <div class="table-title">Event Profiling (<%= h(event_prof_data["event"]) %>)</div>
    <div style="font-size: 11px; color: var(--text-muted); font-family: var(--mono);">
      <%= event_prof_data["total_events"] %> events &middot; <%= event_prof_data["total_time"] %> of <%= event_prof_data["total_run_time"] %> (<%= event_prof_data["total_percentage"] %>%)
    </div>
  </div>
  <table>
    <thead>
      <tr>
        <th>Suite</th>
        <th data-sort>Event Time</th>
        <th data-sort>Events</th>
        <th data-sort>Examples</th>
        <th data-sort>% of Run</th>
      </tr>
    </thead>
    <tbody>
      <% event_prof_data["suites"].each do |suite| -%>
      <tr>
        <td><span class="file-path"><% ep_parts = suite["location"].to_s.sub('./', '').split(':'); %><%= file_link(ep_parts[0], line: ep_parts[1]&.to_i) %></span></td>
        <td><span class="num" style="font-weight: 700;"><%= suite["time"] %></span></td>
        <td><span class="num"><%= suite["event_count"] %></span></td>
        <td><span class="num"><%= suite["example_count"] %></span></td>
        <td><span class="num" style="color: <%= suite["percentage"].to_f > 50 ? 'var(--red)' : suite["percentage"].to_f > 25 ? 'var(--yellow)' : 'var(--text-secondary)' %>;"><%= suite["percentage"] %>%</span></td>
      </tr>
      <% end -%>
    </tbody>
  </table>
</div>
<% end -%>
